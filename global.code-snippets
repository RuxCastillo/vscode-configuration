	"useStateSnippet": {
		"prefix": "useStateSnippet",
		"body": [
			"const [${1:state}, set${1/(.*)/${1:/capitalize}/}] = useState(${2:initialState});",
		],
		"description": "useState hook",
	},
	"useEffectSnippet": {
		"prefix": "useEffectSnippet",
		"body": ["useEffect(() => {", "\t$0", "}, [${1}]);"],
		"description": "useEffect hook",
	},
	"useRefSnippet": {
		"prefix": "useRefSnippet",
