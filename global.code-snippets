	"useQuery custom hook": {
		"prefix": "rqGet",
		"body": [
			"export const useGet${1:Recurso} = () =>",
			"\tuseQuery({",
			"\t\tqueryKey: [\"${2:${1/(.*)/${1:/downcase}/}}\"],",
			"\t\tqueryFn: get${1:Recurso},",
			"\t});$0",
		],
		"description": "Custom hook useQuery simple",
	},
	"useQuery custom hook con params": {
		"prefix": "rqGetParams",
		"body": [
			"export const useGet${1:Recurso} = (${2:params}: ${3:type}) =>",
			"\tuseQuery({",
			"\t\tqueryKey: [\"${4:${1/(.*)/${1:/downcase}/}}\", ${2:params}],",
			"\t\tqueryFn: () => get${1:Recurso}(${2:params}),",
			"\t\tplaceholderData: (prev) => prev,",
			"\t});$0",
		],
		"description": "Custom hook useQuery con parámetros y placeholderData",
	},
	"useMutation custom hook full": {
		"prefix": "rqMutation",
		"body": [
			"export const use${1:Accion}${2:Recurso} = () => {",
			"\tconst queryClient = useQueryClient();",
			"\tconst mutation = useMutation({",
			"\t\tmutationKey: [\"${3:${2/(.*)/${1:/downcase}/}}Mutation${1}\"],",
			"\t\tmutationFn: ${1/(.*)/${1:/downcase}/}${2:Recurso},",
			"\t\tonSuccess: () => {",
			"\t\t\ttoast.success(\"${4:Cambio realizado con éxito}\");",
			"\t\t\tqueryClient.invalidateQueries({ queryKey: [\"${3:${2/(.*)/${1:/downcase}/}}\"] });",
			"\t\t},",
			"\t\tonError: () =>",
			"\t\t\ttoast.error(",
			"\t\t\t\t\"${5:Sucedio un error en la operación, por favor intentelo mas tarde}\"",
			"\t\t\t),",
			"\t});",
			"\treturn mutation;",
			"};$0",
		],
		"description": "Custom hook useMutation con queryClient, toast e invalidate",
	},
	"useMutation custom hook simple": {
		"prefix": "rqMutationSimple",
		"body": [
			"export const use${1:Accion}${2:Recurso} = () =>",
			"\tuseMutation({",
			"\t\tmutationKey: [\"${3:${1/(.*)/${1:/downcase}/}${2}}\"],",
			"\t\tmutationFn: ${1/(.*)/${1:/downcase}/}${2:Recurso},",
			"\t});$0",
		],
		"description": "Custom hook useMutation simple sin queryClient",
	},
	"guard isLoading": {
		"prefix": "ifLoading",
		"body": ["if (isLoading || !data) {", "\treturn <IsLoading />;", "}$0"],
		"description": "Guard clause para isLoading",
	},
	"guard isError": {
		"prefix": "ifError",
		"body": [
			"if (isError) {",
			"\treturn <IsError refetch={refetch} />;",
			"}$0",
		],
		"description": "Guard clause para isError con refetch",
	},
	"guard isLoading + isError": {
		"prefix": "ifGuards",
		"body": [
			"if (isLoading || !data) {",
			"\treturn <IsLoading />;",
			"}",
			"if (isError) {",
			"\treturn <IsError refetch={refetch} />;",
			"}$0",
		],
		"description": "Ambos guards juntos",
	},
	"uso useGet con guards": {
		"prefix": "rqUseGet",
		"body": [
			"const { data, isLoading, refetch, isError } = useGet${1:Recurso}(${2:params});",
			"if (isLoading || !data) {",
			"\treturn <IsLoading />;",
			"}",
			"if (isError) {",
			"\treturn <IsError refetch={refetch} />;",
			"}$0",
		],
		"description": "Uso de hook custom + guards",
	},
